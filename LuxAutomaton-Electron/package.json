{
  "name": "Lux Automaton",
  "version": "1.0.0",
  "description": "Complete AI Automation Studio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg"
  },
  "author": "Lux Automaton",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.luxautomaton.app",
    "productName": "Lux Automaton",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icon.icns",
      "target": ["dmg"]
    },
    "dmg": {
      "title": "Lux Automaton Installer"
    }
  }
}
